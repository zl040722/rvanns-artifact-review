+                    vacc2 = __riscv_vfmacc_vv_f32m2(vacc2, x1_2, x2_2, vlmax);
+                    vacc3 = __riscv_vfmacc_vv_f32m2(vacc3, x1_3, x2_3, vlmax);
+                }
+            }
+        }
+
+        for (; i < d;) {
+            size_t vl;
+            if constexpr (
+                    std::is_same_v<Quantizer, QuantizerFP16_rvv<0>> ||
+                    std::is_same_v<Quantizer, QuantizerBF16_rvv<0>>) {
